# ═══════════════════════════════════════════════════════════
# Code Typist Arcade — Backend (.gitignore)
# ═══════════════════════════════════════════════════════════

# Dependencies
node_modules/

# Build output
dist/

# Environment (NEVER commit secrets)
.env
.env.local
.env.*.local

# Prisma generated client (auto-generated, not source code)
src/generated/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / IDE
.vscode/
.idea/
*.suo
*.sw?

# OS
.DS_Store
Thumbs.db

# TypeScript build info
*.tsbuildinfo

# Coverage
coverage/
.nyc_output/
